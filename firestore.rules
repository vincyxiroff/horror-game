rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (optional)
    //   - displayName: string (optional)
    //   - sanity: number (optional)
    //   - tension: number (optional)
    //   - inventory: list (optional)
    //   - checkpoint: map (optional)
    //   - settings: map (optional)
    //   - updatedAt: timestamp (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string &&
             (!('email' in data) || data.email is string) &&
             (!('sanity' in data) || (data.sanity is number && data.sanity >= 0 && data.sanity <= 100)) &&
             (!('tension' in data) || (data.tension is number && data.tension >= 0 && data.tension <= 100)) &&
             (!('inventory' in data) || data.inventory is list);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Users cannot delete their profiles for now
    }
  }
}
