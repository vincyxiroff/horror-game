{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user progress and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "sanity": { "type": "number" },
        "tension": { "type": "number" },
        "inventory": { "type": "array", "items": { "type": "string" } },
        "checkpoint": { "type": "object" },
        "settings": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User-specific data"
    }
  }
}
